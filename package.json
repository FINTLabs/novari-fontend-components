        "playwright": "^1.61.0",
        "postcss": "^8.5.3",
        "rollup": "^4.35.0",
        "rollup-plugin-dts": "^6.4.1",
        "rollup-plugin-peer-deps-external": "^2.2.4",
        "rollup-plugin-postcss": "^4.0.2",
        "storybook": "^10.1.10",
        "typescript": "~6.0.3",
        "typescript-eslint": "^8.61.1",
        "vite": "^7.3.0",
        "vitest": "^4.1.9"
