        "react-dom": ">=18.0.0",
        "tailwindcss": ">=4.0.13"
    },
    "eslintConfig": {
        "extends": [
            "plugin:storybook/recommended"
        ]
    },
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "style": "./lib/index.css",
            "import": "./lib/index.mjs",
            "require": "./lib/index.cjs",
            "default": "./lib/index.mjs"
        },
        "./lib/index.css": {
            "default": "./lib/index.css"
        }
